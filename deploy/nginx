upstream bioko_ministerio {
    server 127.0.0.1:5000;
    keepalive 32;
}

server {
    listen 80 default_server;
    server_name _;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name central.biokohealth.gq;
    server_tokens off;
    client_max_body_size 20M;

    # SSL — certbot popula estas líneas automáticamente
    # ssl_certificate     /etc/letsencrypt/live/central.biokohealth.gq/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/central.biokohealth.gq/privkey.pem;

    location / {
        proxy_pass         http://bioko_ministerio;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto https;
        proxy_read_timeout 120s;
    }

    location /api/sync/ {
        proxy_pass         http://bioko_ministerio;
        proxy_set_header   Host $host;
        proxy_read_timeout 60s;
        proxy_buffering    off;
    }

    location /static/ {
        alias /opt/bioko_health/app/static/;
        expires 7d;
        access_log off;
    }

    location /reportes/ {
        proxy_pass http://bioko_ministerio;
        proxy_read_timeout 180s;
    }

    add_header Strict-Transport-Security "max-age=31536000" always;
    add_header X-Frame-Options "SAMEORIGIN";
    add_header X-Content-Type-Options "nosniff";
    access_log /var/log/nginx/bioko_ministerio_access.log;
    error_log  /var/log/nginx/bioko_ministerio_error.log warn;
}
